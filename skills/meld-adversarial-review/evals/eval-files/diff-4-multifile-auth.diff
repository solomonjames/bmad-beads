@@ -0,0 +1,47 @@
+import { Router } from 'express';
+import { authenticate, authorize, AuthRequest } from '../middleware/auth';
+import { db } from '../db';
+
+const router = Router();
+
+router.use(authenticate);
+
+router.get('/admin/users', authorize('admin'), async (req: AuthRequest, res) => {
+  const users = await db.query('SELECT id, name, email, role FROM users');
+  res.json(users.rows);
+});
+
+router.put('/admin/users/:id/role', authorize('admin'), async (req: AuthRequest, res) => {
+  const { id } = req.params;
+  const { role } = req.body;
+
+  await db.query('UPDATE users SET role = $1 WHERE id = $2', [role, id]);
+  res.json({ success: true });
+});
+
+router.delete('/admin/users/:id', authorize('admin'), async (req: AuthRequest, res) => {
+  const { id } = req.params;
+  const adminId = req.user!.id;
+
+  // Prevent self-deletion
+  if (id === adminId) {
+    return res.status(400).json({ error: 'Cannot delete yourself' });
+  }
+
+  await db.query('DELETE FROM users WHERE id = $1', [id]);
+  res.json({ success: true });
+});
+
+router.get('/admin/audit-log', authorize('admin', 'auditor'), async (req: AuthRequest, res) => {
+  const { startDate, endDate, action } = req.query;
+
+  let query = 'SELECT * FROM audit_log WHERE 1=1';
+  const params: any[] = [];
+
+  if (startDate) { query += ` AND created_at >= '${startDate}'`; params.push(startDate); }
+  if (endDate) { query += ` AND created_at <= '${endDate}'`; params.push(endDate); }
+  if (action) { query += ` AND action = '${action}'`; params.push(action); }
+
+  const logs = await db.query(query, params);
+  res.json(logs.rows);
+});
+
+export default router;
