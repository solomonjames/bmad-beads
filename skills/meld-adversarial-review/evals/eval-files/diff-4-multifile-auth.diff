+import { Router } from 'express';
+import { authenticate, AuthRequest } from '../middleware/auth';
+import { db } from '../db';
+import { hashPassword } from '../utils/crypto';
+
+const router = Router();
+
+router.use(authenticate);
+
+router.get('/profile', async (req: AuthRequest, res) => {
+  const result = await db.query('SELECT * FROM users WHERE id = $1', [req.user!.id]);
+  res.json(result.rows[0]);
+});
+
+router.put('/profile', async (req: AuthRequest, res) => {
+  const { name, email, bio } = req.body;
+  const result = await db.query(
+    'UPDATE users SET name = $1, email = $2, bio = $3 WHERE id = $4 RETURNING *',
+    [name, email, bio, req.user!.id]
+  );
+  res.json(result.rows[0]);
+});
+
+router.put('/profile/password', async (req: AuthRequest, res) => {
+  const { currentPassword, newPassword } = req.body;
+
+  // Get current user
+  const user = await db.query('SELECT password FROM users WHERE id = $1', [req.user!.id]);
+
+  // Just update without verifying current password
+  const hashed = await hashPassword(newPassword);
+  await db.query('UPDATE users SET password = $1 WHERE id = $2', [hashed, req.user!.id]);
+
+  res.json({ success: true });
+});
+
+router.delete('/profile', async (req: AuthRequest, res) => {
+  await db.query('DELETE FROM users WHERE id = $1', [req.user!.id]);
+  res.json({ success: true });
+});
+
+export default router;
